<!--  Views/CircleView.axaml  -->
<UserControl
    x:Class="MathApp.Views.CircleView"
    x:DataType="vm:CircleViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:vm="using:MathApp.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Background="White"
        BoxShadow="0 8 30 0 #44000000"
        CornerRadius="12"
        HorizontalAlignment="Center"
        Padding="28"
        VerticalAlignment="Center"
        Width="380">

        <StackPanel Spacing="14">
            <TextBlock
                FontSize="20"
                FontWeight="Bold"
                Text="⭕ Cerc" />
            <TextBlock
                FontSize="13"
                Foreground="Gray"
                Text="Introduceți raza:" />

            <Grid ColumnDefinitions="Auto,*">
                <TextBlock
                    Grid.Column="0"
                    Margin="0,0,12,0"
                    Text="Raza (r):"
                    VerticalAlignment="Center" />
                <TextBox
                    Grid.Column="1"
                    Text="{Binding InputRadius}"
                    Watermark="ex: 7.5" />
            </Grid>

            <Button
                Command="{Binding CalculateCommand}"
                Content="Calculează"
                HorizontalAlignment="Stretch" />

            <Border
                Background="#F1F8E9"
                CornerRadius="8"
                IsVisible="{Binding HasResult}"
                Padding="14">
                <TextBlock
                    FontSize="13"
                    Text="{Binding Result}"
                    TextWrapping="Wrap" />
            </Border>

            <Border
                Background="Black"
                CornerRadius="8"
                HorizontalAlignment="Right">
                <Button
                    Command="{Binding CloseCommand}"
                    Content="Închide"
                    HorizontalAlignment="Right" />
            </Border>

        </StackPanel>
    </Border>
</UserControl>