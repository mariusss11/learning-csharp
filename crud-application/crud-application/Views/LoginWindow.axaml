<UserControl
    Background="#0b0f1a"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="crud_application.Views.LoginWindow"
    x:DataType="vm:LoginViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:crud_application.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  ===== Styles =====  -->
    <UserControl.Styles>

        <!--  Glass Card  -->
        <Style Selector="Border.login-card">
            <Setter Property="Background">
                <LinearGradientBrush EndPoint="100%,100%" StartPoint="0%,0%">
                    <GradientStop Color="#22ffffff" Offset="0" />
                    <GradientStop Color="#10ffffff" Offset="1" />
                </LinearGradientBrush>
            </Setter>
            <Setter Property="BorderBrush" Value="#35ffffff" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="30" />
            <Setter Property="Effect">
                <DropShadowEffect
                    BlurRadius="30"
                    Color="#40000000"
                    OffsetY="10" />
            </Setter>
        </Style>

        <!--  Titles  -->
        <Style Selector="TextBlock.title">
            <Setter Property="Foreground" Value="#f8fafc" />
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style Selector="TextBlock.subtitle">
            <Setter Property="Foreground" Value="#94a3b8" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <!--  Inputs  -->
        <Style Selector="TextBox.login-input">
            <Setter Property="Background" Value="#111827" />
            <Setter Property="Foreground" Value="#f9fafb" />
            <Setter Property="BorderBrush" Value="#374151" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Height" Value="48" />
        </Style>

        <Style Selector="TextBox.login-input:focus">
            <Setter Property="BorderBrush" Value="#818cf8" />
        </Style>

        <!--  Primary Button  -->
        <Style Selector="Button.primary-btn">
            <Setter Property="Background">
                <LinearGradientBrush EndPoint="100%,100%" StartPoint="0%,0%">
                    <GradientStop Color="#6366f1" Offset="0" />
                    <GradientStop Color="#4338ca" Offset="1" />
                </LinearGradientBrush>
            </Setter>
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Height" Value="48" />
        </Style>

        <!--  Secondary Button  -->
        <Style Selector="Button.link-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#a5b4fc" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10" />

        </Style>

        <!--  Error  -->
        <Style Selector="TextBlock.error">
            <Setter Property="Foreground" Value="#f87171" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

    </UserControl.Styles>

    <!--  ===== Layout =====  -->
    <Grid>
        <Border
            Classes="login-card"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="400">

            <StackPanel Spacing="18">

                <!--  Header  -->
                <StackPanel Spacing="6">
                    <TextBlock
                        Classes="title"
                        HorizontalAlignment="Center"
                        Text="Welcome Back" />

                    <TextBlock
                        Classes="subtitle"
                        HorizontalAlignment="Center"
                        Text="Login to your account" />
                </StackPanel>

                <!--  Inputs  -->
                <StackPanel Spacing="12">
                    <TextBox
                        Classes="login-input"
                        Text="{Binding Username}"
                        Watermark="Username" />

                    <TextBox
                        Classes="login-input"
                        PasswordChar="●"
                        Text="{Binding Password}"
                        Watermark="Password" />
                </StackPanel>

                <!--  Error  -->
                <TextBlock Classes="error" Text="{Binding ErrorMessage}" />

                <!--  Actions  -->
                <StackPanel HorizontalAlignment="Center" Spacing="12">
                    <Button
                        Classes="primary-btn"
                        Command="{Binding LoginCommand}"
                        Content="Login"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center" />

                    <Button
                        Classes="link-btn"
                        Command="{Binding ChangeToRegisterCommand}"
                        Content="Create an account" />
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>

</UserControl>
