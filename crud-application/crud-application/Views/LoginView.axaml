<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="crud_application.Views.LoginView"
    x:DataType="vm:LoginViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:crud_application.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  fdfd  -->

    <DockPanel Margin="10">
        <TextBlock
            DockPanel.Dock="Top"
            FontSize="26"
            FontWeight="Medium"
            HorizontalAlignment="Center"
            Margin="0,10,0,20"
            Text="Login"
            VerticalAlignment="Center" />


        <StackPanel DockPanel.Dock="Bottom">
            <TextBlock HorizontalAlignment="Center" Text="Error Message" />
            <Button
                Command="{Binding LoginCommand}"
                Content="Login"
                FontSize="18"
                Height="50"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Margin="0,10,0,0"
                VerticalContentAlignment="Center" />
        </StackPanel>


        <!--  Content  -->
        <StackPanel Spacing="10">
            <TextBox
                AcceptsReturn="False"
                FontSize="16"
                Height="50"
                Margin="5"
                MaxLines="1"
                Padding="10"
                Text="{Binding Username}"
                VerticalContentAlignment="Center" />

            <TextBox
                AcceptsReturn="False"
                FontSize="16"
                Height="50"
                Margin="5"
                MaxLines="1"
                Padding="10"
                PasswordChar="*"
                Text="{Binding Password}"
                VerticalContentAlignment="Center" />
        </StackPanel>

    </DockPanel>

</UserControl>
